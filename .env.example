# LLM Configuration
MODEL=ollama/qwen3.5:27b
# For Mistral, swap to: MODEL=ollama/mistral-small:24b
OLLAMA_BASE_URL=http://localhost:11434

# Authentication
# JWT signing secret — generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-generate-a-real-secret!!
# Invite code — only people who know this can register an account
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(12))"
INVITE_CODE=change-me-pick-a-code

# API Keys
SERPER_API_KEY=your_serper_api_key_here

# Image Generation
# Backend: "zimage" (Z-Image-Turbo), "sd" (Stable Diffusion v1.5), or "none"
IMAGE_BACKEND=zimage
# ZImage settings
ZIMAGE_MODEL=mrfakename/Z-Image-Turbo
ZIMAGE_WIDTH=512
ZIMAGE_HEIGHT=512
# Stable Diffusion settings
# SD_MODEL=stable-diffusion-v1-5/stable-diffusion-v1-5
# HuggingFace token (for gated model downloads; optional after first download)
# HUGGINGFACE_TOKEN=hf_your_token_here
# Set to 1 after first model download for fully offline operation
TRANSFORMERS_OFFLINE=0
